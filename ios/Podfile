platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting build performance.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

# The standard Flutter integration depends on podhelper.rb
# We wrap this in a check to avoid the 'cannot load such file' error
podhelper_path = File.join('..', 'Flutter', 'podhelper.rb')

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  if File.exist?(podhelper_path)
    require File.expand_path(podhelper_path, __FILE__)
    flutter_install_all_ios_pods File.expand_path(File.join('..'), __FILE__)
  else
    # Fallback: if podhelper.rb is missing, we can't install Flutter pods.
    # User must run 'flutter pub get' or 'flutter create .' to generate it.
    puts "Warning: Flutter/podhelper.rb not found. Run 'flutter pub get' first."
  end

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Only call if the helper was loaded
    if respond_to?(:flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end
    
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    end
  end
end
